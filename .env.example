# Скопируйте в .env и заполните значения. Файл .env не коммитится.

DJANGO_SECRET_KEY=замените-на-случайную-строку
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Почта (для подтверждения регистрации и уведомлений о заказах)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=no-reply@example.com

# Ящик для накладных и служебных уведомлений по заказам (администратор)
ADMIN_ORDER_EMAIL=admin@example.com

# Celery / Redis
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
